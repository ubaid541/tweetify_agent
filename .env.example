# ============================================================
# Tweetify — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# --- Twitter / X API v2 ---
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here
TWITTER_BEARER_TOKEN=your_bearer_token_here

# --- Gemini (for AI extraction and tweet generation) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Gmail API ---
# Place credentials.json in the project root (download from Google Cloud Console)
# token.json is auto-generated after first OAuth run — do NOT commit either file
# See workflows/fetch_newsletter.md for full setup instructions
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# --- Newsletter Senders to Monitor ---
# Comma-separated list of sender email addresses
NEWSLETTER_SENDERS=crew@community.morningbrew.com,futuretools@mail.beehiiv.com

# --- General ---
LOG_LEVEL=INFO
